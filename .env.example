# Copy to .env and fill in. NEVER commit real values — this repo is public.
# In production these are injected by Coolify; club-specific/secret values also
# live in the admin-only `settings` table.

# --- Database (Postgres) ---
# Local dev with the bundled docker-compose Postgres:
DATABASE_URL=postgres://toastily:toastily@localhost:5432/toastily

# --- Auth (nuxt-auth-utils) — used from P2 onward ---
# Generate one: `openssl rand -base64 32`  (min 32 chars)
NUXT_SESSION_PASSWORD=

# --- Public ---
# Public base URL of the site (used for absolute links, QR target default, etc.)
SITE_URL=http://localhost:3000

# --- Email (Resend) — used from P7. Preferably set via admin `settings` table. ---
# BOTH are required for delivery: with only one set, email is NOT sent (the app
# logs an "[email misconfigured]" warning and falls back to a no-op stub).
# EMAIL_FROM must be a sender on a Resend-verified domain.
# RESEND_API_KEY=
# EMAIL_FROM=

# --- Image storage (S3-compatible) — issue #10, PRD §2/§15 ---
# Backend-agnostic: MinIO on Coolify, Cloudflare R2, Backblaze B2, or AWS S3.
# Leave S3_ENDPOINT empty to disable uploads (the /api/uploads route returns 503).
# Secrets are injected by Coolify in production — never commit real values.
#
# For the bundled docker-compose MinIO (local dev), these defaults work as-is:
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=toastily-uploads
S3_ACCESS_KEY=toastily
S3_SECRET_KEY=toastily-secret
# MinIO/self-hosted need path-style addressing (set to "false" only for AWS S3).
S3_FORCE_PATH_STYLE=true
# Public base URL of the bucket. If set, uploads return "<base>/<key>" directly;
# if empty, images are proxied through Nitro at /api/uploads/<key>.
# Local MinIO console serves objects at http://localhost:9000/<bucket>:
S3_PUBLIC_BASE_URL=http://localhost:9000/toastily-uploads
# Max upload size in bytes (default 5 MB).
# S3_MAX_BYTES=5242880

# --- MinIO container (docker-compose, local dev) ---
MINIO_ROOT_USER=toastily
MINIO_ROOT_PASSWORD=toastily-secret
MINIO_BUCKET=toastily-uploads

# --- Postgres container (docker-compose) ---
POSTGRES_USER=toastily
POSTGRES_PASSWORD=toastily
POSTGRES_DB=toastily
